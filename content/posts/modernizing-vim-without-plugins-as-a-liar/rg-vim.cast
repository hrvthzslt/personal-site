[10.858133, "o", "\u001b[1;5H\u001b[95m    If view looked like this and you want to add a new header::\u001b[3;5H        def index():\u001b[m\u001b[4;3H\u001b[93m7\u001b[m\u001b[1C\u001b[95m            return render_template('index.html', foo=42)\u001b[m\u001b[5;17H             \u001b[6;5H\u001b[95m    You can now do something like this::\u001b[m     \u001b[7;17H                             \u001b[8;5H\u001b[95m        def index():\u001b[m\r\n\u001b[1m\u001b[7mvenv/lib/python3.13/site-packages/flask/helpers.py\u001b[11C7,20\u001b[9C21\u001b[m\u001b[10;3H\u001b[93m3\r\n  2\r\n  1\u001b[m\u001b[1C\u001b[38;5;159msrc/blueprint/markdown_server/responder.py\u001b[m\u001b[38;5;224m|\u001b[m\u001b[93m13 col 9\u001b[m\u001b[38;5;224m|\u001b[m render_template(    \u001b[13;1H\u001b[93m4  \u001b[m\u001b[1C\u001b[30m\u001b[103mvenv/lib/python3.13/site-packages/flask/helpers.py|137 col 20| return ren\u001b[m\u001b[14;3H\u001b[93m1\r\n  2\r\n  3\r\n  4\r\n  5\r\n  6\u001b[m\u001b[20;59H\u001b[7m4\u001b]2;helpers.py (~/workspace/persona...3.13/site-packages/flask) - VIM\u0007\u001b[4;24H\u001b[?25h"]
[11.828006, "o", "\u001b[?25l\u001b[m\u001b[21;1H\u001b[K\u001b[21;1H:cnext\r"]
[11.830591, "o", "\u001b[1;3H\u001b[93m4\u001b[m\u001b[1C                                                               \u001b[2;3H\u001b[93m3\u001b[m\u001b[1C\u001b[95m    You can now do something like this::\u001b[m\u001b[3;3H\u001b[93m2\u001b[m\u001b[1C                    \r\n\u001b[93m  1\u001b[m\u001b[9C\u001b[95mdef index():\u001b[m                                    \r\n\u001b[93m142\u001b[m\u001b[1C\u001b[95m            response = make_response(render_template('index.html', foo=42\u001b[m\u001b[6;3H\u001b[93m1\u001b[m\u001b[5C\u001b[95m        response.headers['X-Parachutes'] = 'parachutes are cool'\u001b[m\u001b[7;3H\u001b[93m2\u001b[m\u001b[1C\u001b[95m            return response\u001b[m\u001b[8;3H\u001b[93m3\u001b[m\u001b[1C                    \u001b[1;8r\u001b[8;1H\r\n\u001b[1;21r\u001b[8;1H\u001b[93m  4 \u001b[m\u001b[95m    This function accepts the very same arguments you can return from a\u001b[m\u001b[9;61H\u001b[1m\u001b[7m42,38 \u001b[9C2%\u001b[m\u001b[10;3H\u001b[93m4\r\n  3\r\n  2\r\n  1\u001b[m\u001b[1C\u001b[38;5;159mvenv/lib/python3.13/site-packages/flask/helpers.py\u001b[m\u001b[38;5;224m|\u001b[m\u001b[93m137 col 20\u001b[m\u001b[38;5;224m|\u001b[m return ren\u001b[14;1H\u001b[93m5  \u001b[m\u001b[1C\u001b[30m\u001b[103mvenv/lib/python3.13/site-packages/flask/helpers.py|142 col 38| response =\u001b[m\u001b[15;3H\u001b[93m1\r\n  2\r\n  3\r\n  4\r\n  5\u001b[m\u001b[20;59H\u001b[7m5\u001b[m\u001b[21;1H\u001b[K\u001b[4;42H\u001b[?25h"]

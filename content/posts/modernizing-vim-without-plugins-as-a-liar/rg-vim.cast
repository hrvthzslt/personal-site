[10.458499, "o", "\u001b[1;5H                                                                        \u001b[2;7H\u001b[34mThis should take Exception, but that either breaks typing the argum\u001b[3;7Hwith a specific exception, or decorating multiple times with different\u001b[4;7Hexceptions (and using a union type on the argument).\u001b[5;48H0\u001b[m\u001b[6;2H\u001b[38;5;130m0\u001b[m\u001b[47C\u001b[34m5\u001b[7;5H# https://github.com/pallets/flask/issues/4297\u001b[m\u001b[8;5HErrorHandlerCallable = t.Union[              \u001b[9;29HResponseReturnValue],             \u001b[10;5H    t.Callable[[t.Any], t.Awaitable[ResponseReturnValue]],\u001b[11;5H]\u001b[12;5H                        \u001b[13;76H\u001b[1m\u001b[7m0,\u001b[13C4%\u001b[m\u001b[14;3H\u001b[38;5;130m8\r\n  7\r\n  6\r\n  5\r\n  4\r\n  3\r\n  2\r\n  1\r\n133\u001b[m\u001b[1C\u001b[34m\u001b[103mvenv/lib/python3.13/site-packages/flask/typing.py\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[38;5;130m\u001b[103m80 col 30\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[103m # https://github.com/pallet\u001b[m\u001b[23;1H\u001b[38;5;130m  1\u001b[m\u001b[1C\u001b[34mvenv/lib/python3.13/site-packages/flask/typing.py\u001b[m\u001b[35m|\u001b[m\u001b[38;5;130m81 col 30\u001b[m\u001b[35m|\u001b[m # https://github.com/pallet\u001b[24;76H\u001b[7m3\u001b[6;34H\u001b[?25h"]

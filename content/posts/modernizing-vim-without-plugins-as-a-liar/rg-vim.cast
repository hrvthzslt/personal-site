[16.495462, "o", "\u001b[1;3H\u001b[38;5;130m6\u001b[m\u001b[1C\u001b[31m    :class:`ContextVar` containing a :class:`dict` value.\u001b[m\u001b[2;3H\u001b[38;5;130m5\r\n  4\u001b[m\u001b[1C\u001b[31m    This may incur a performance penalty compared to using individual\u001b[m\u001b[4;3H\u001b[38;5;130m3\u001b[m\u001b[1C\u001b[31m    context vars, as it has to copy data to avoid mutating the dict\u001b[m\u001b[5;3H\u001b[38;5;130m2\u001b[m\u001b[1C\u001b[31m    between nested contexts.\u001b[m                                 \r\n\u001b[38;5;130m  1\u001b[m\u001b[1C                                                         \r\n\u001b[38;5;130m43 \u001b[m\u001b[1C\u001b[31m    :param context_var: The :class:`~contextvars.ContextVar` to use as\u001b[m\u001b[8;3H\u001b[38;5;130m1\u001b[m\u001b[5C\u001b[31m    storage for this local. If not given, one will be created.\u001b[m   \u001b[9;3H\u001b[38;5;130m2\u001b[m\u001b[5C\u001b[31m    Context vars not created at the global scope may interfere with\u001b[m\u001b[10;3H\u001b[38;5;130m3\u001b[m\u001b[5C\u001b[31m    garbage collection.\u001b[m \u001b[11;3H\u001b[38;5;130m4\r\n  5\u001b[m\u001b[5C\u001b[31m.. versionchanged:: 2.0\u001b[m                                           \u001b[1;12r\u001b[12;1H\r\n\u001b[1;25r\u001b[12;1H\u001b[38;5;130m  6 \u001b[m\u001b[31m        Uses ``ContextVar`` instead of a custom storage implementation.\u001b[m\u001b[13;75H\u001b[1m\u001b[7m43,50 \u001b[10C5%\u001b[m\u001b[14;3H\u001b[38;5;130m2\r\n  1\u001b[m\u001b[1C\u001b[34mvenv/lib/python3.13/site-packages/werkzeug/local.py\u001b[m\u001b[35m|\u001b[m\u001b[38;5;130m37 col 13\u001b[m\u001b[35m|\u001b[m :class:`ContextVar` conta\u001b[16;1H\u001b[38;5;130m3  \u001b[m\u001b[1C\u001b[34m\u001b[103mvenv/lib/python3.13/site-packages/werkzeug/local.py\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[38;5;130m\u001b[103m43 col 50\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[103m :param context_var: The :\u001b[m\u001b[17;3H\u001b[38;5;130m1\r\n  2\r\
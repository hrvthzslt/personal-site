[9.151498, "o", "\u001b[?25l\u001b[m\u001b[1;3H\u001b[38;5;130m5 \u001b[m\u001b[34m# This should take Exception, but that either breaks typing the argument\u001b[m\u001b[2;3H\u001b[38;5;130m4 \u001b[m\u001b[34m# with a specific exception, or decorating multiple times with different\u001b[m\u001b[3;3H\u001b[38;5;130m3 \u001b[m\u001b[34m# exceptions (and using a union type on the argument).\u001b[m\u001b[4;3H\u001b[38;5;130m2 \u001b[m\u001b[34m# https://github.com/pallets/flask/issues/4095\u001b[m\u001b[5;3H\u001b[38;5;130m1 \u001b[m\u001b[34m# https://github.com/pallets/flask/issues/4295\u001b[m\r\n\u001b[38;5;130m81\u001b[m\u001b[2C\u001b[34m# https://github.com/pallets/flask/issues/4297\u001b[m\u001b[7;3H\u001b[38;5;130m1 \u001b[mErrorHandlerCallable = t.Union[\u001b[8;3H\u001b[38;5;130m2 \u001b[m    t.Callable[[t.Any], ResponseReturnValue],\u001b[9;3H\u001b[38;5;130m3 \u001b[m    t.Callable[[t.Any], t.Awaitable[ResponseReturnValue]],\u001b[10;3H\u001b[38;5;130m4 \u001b[m]                         \u001b[11;3H\u001b[38;5;130m5 \u001b[m                                         \u001b[12;3H\u001b[38;5;130m6 \u001b[mRouteCallable = t.Union[\r\n\u001b[1m\u001b[7mvenv/lib/python3.13/site-packages/flask/typing.py                         81,30          96%\u001b[m\u001b[23;5H\u001b[34m\u001b[103mvenv/lib/python3.13/site-packages/flask/typing.py\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[38;5;130m\u001b[103m81 col 30\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[103m # https://github.com/pallet\u001b[m\u001b[24;1H\u001b[7m<p --hidden --no-ignore -g '!tags' -g '!.git/**' -w -g \"*.py\" -- 'flask' 134,1           Bot\u001b]2;typing.py (~/workspace/personal/markd.../python3.13/site-packages/flask) - VIM\u0007\u001b[6;34H\u001b[?25h"]

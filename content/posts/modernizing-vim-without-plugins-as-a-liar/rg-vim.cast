[11.321216, "o", "\u001b[1;9H                  \u001b[2;5H\u001b[31mThis typically means that you attempted to use functionality that needed\u001b[3;5Han active HTTP request. Consult the documentation on testing for\u001b[4;5Hinformation about how to avoid this problem.\u001b[m\u001b[35m\\\u001b[m                         \u001b[5;5H\u001b[31m\"\"\"\u001b[m                                                               \u001b[6;2H\u001b[38;5;130m2\u001b[m\u001b[2C_cv_request: ContextVar[RequestContext] = ContextVar(\u001b[31m\"flask.request_ctx\"\u001b[m)\u001b[7;5Hrequest_ctx: RequestContext = LocalProxy(  \u001b[34m# type: ignore[assignment]\u001b[m\u001b[8;9H_cv_request, unbound_message=_no_req_msg\u001b[9;5H)                                                                                       \u001b[10;5Hrequest: Request = LocalProxy(  \u001b[34m# type: ignore[assignment]\u001b[m\u001b[11;9H_cv_request, \u001b[31m\"request\"\u001b[m, unbound_message=_no_req_msg\u001b[12;5H)                                                           \u001b[13;41H\u001b[1m\u001b[7mglobals.py\u001b[25C2,55 \u001b[9C92%\u001b[m\u001b[14;3H\u001b[38;5;130m5\r\n  4\r\n  3\r\n  2\r\n  1\r\n130\u001b[m\u001b[1C\u001b[34m\u001b[103mvenv/lib/python3.13/site-packages/flask/globals.py\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[38;5;130m\u001b[103m42 col 55\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[103m _cv_request: ContextVar[Re\u001b[m\u001b[20;1H\u001b[38;5;130m  \u001b[m\u001b[2C\u001b[34mvenv/lib/python3.13/site-packages/flask/typing.py\u001b[m\u001b[35m|\u001b[m\u001b[38;5;130m44 col 27\u001b[m\u001b[35m|\u001b[m # callback annotated with f\u001b[21;3H\u001b[38;5;130m2\r\n  3\r\n  4\u001b[m\u001b[24;76H\u001b[7m0\u001b]2;globals.py (~/workspace/personal/mark.../python3.13/site-packages/flask) - VIM\u0007\u001b[6;59H\u001b[?25h"]

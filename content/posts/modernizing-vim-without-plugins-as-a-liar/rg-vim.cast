[22.567151, "o", "\u001b[?25l\u001b[m\u001b[1;2H\u001b[38;5;130m10\u001b[m\u001b[5C\u001b[31m    garbage collection.\u001b[m\u001b[2;3H\u001b[38;5;130m9\u001b[m\u001b[1C       \u001b[3;3H\u001b[38;5;130m8\u001b[m\u001b[1C\u001b[31m    .. versionchanged:: 2.0\u001b[m\u001b[4;3H\u001b[38;5;130m7\u001b[m\u001b[1C\u001b[31m        Uses ``ContextVar`` instead of a custom storage implementation.\u001b[m\u001b[5;3H\u001b[38;5;130m6\r\n  5\u001b[m\u001b[1C\u001b[31m    .. versionadded:: 0.6.1\u001b[m                                                    \u001b[7;3H\u001b[38;5;130m4\u001b[m\u001b[1C\u001b[31m    \"\"\"\u001b[m                        \u001b[8;3H\u001b[38;5;130m3\u001b[m\u001b[13C                                                          \u001b[9;3H\u001b[38;5;130m2\u001b[m\u001b[5C__slots__ = (\u001b[31m\"_storage\"\u001b[m,)                                         \u001b[10;3H\u001b[38;5;130m1\u001b[m\u001b[13C                                                          \r\n\u001b[38;5;130m127 \u001b[m    \u001b[38;5;130mdef\u001b[m \u001b[36m__init__\u001b[m(self, context_var: ContextVar[\u001b[36mlist\u001b[m[T]] | \u001b[36mNone\u001b[m = \u001b[36mNone\u001b[m) -> \u001b[36mNone\u001b[m:\u001b[12;3H\u001b[38;5;130m1\u001b[9Cif\u001b[m context_var \u001b[38;5;130mis\u001b[m \u001b[36mNone\u001b[m:                                                 \r\n\u001b[38;5;130m  2 \u001b[m            \u001b[34m# A ContextVar not created at global scope interferes with\u001b[m                  \u001b[14;3H\u001b[38;5;130m3\u001b[m\u001b[1C            \u001b[34m# Python's garbage collection. However, a local only makes\u001b[m                  \u001b[15;3H\u001b[38;5;130m4\u001b[m\u001b[1C            \u001b[34m# sense defined at the global scope as well, in which case\u001b[m                  \u001b[16;3H\u001b[38;5;130m5\u001b[m\u001b[1C            \u001b[34m# the GC issue doesn't seem relevant\u001b[m\u001b[1C                                      \u001b[17;3H\u001b[38;5;130m6\u001b[m\u001b[1C            context_var = ContextVar(f\u001b[31m\"werkzeug.LocalStack<{id(self)}>.storage\"\u001b[m)        \u001b[18;1H\u001b[38;5;130m  7\u001b[m\u001b[1C                                                                                        \u001b[19;3H\u001b[38;5;130m8\u001b[m\u001b[1C        self._storage = context_var                                                     \u001b[20;3H\u001b[38;5;130m9\u001b[m\u001b[1C                                                                                        \u001b[21;2H\u001b[38;5;130m10\u001b[m\u001b[1C    \u001b[38;5;130mdef"]
[22.567263, "o", "\u001b[m \u001b[36m__release_local__\u001b[m(self) -> \u001b[36mNone\u001b[m:                                                \u001b[22;2H\u001b[38;5;130m11\u001b[m\u001b[1C        self._storage.set([])                                                           \u001b[23;2H\u001b[38;5;130m12\u001b[m\u001b[1C                                                                                        \u001b[24;1H\u001b[1m\u001b[7mvenv/lib/python3.13/site-packages/werkzeug/local.py                       127,37         18%\u001b[11;41H\u001b[?25h"]

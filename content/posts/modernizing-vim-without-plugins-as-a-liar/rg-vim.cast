[10.996743, "o", "\u001b[1;5H    \u001b[31m\"WSGIApplication\"\u001b[m,\u001b[2;5H]\u001b[3;5H                                                                        \u001b[4;7H\u001b[34mAllow any subclass of werkzeug.Response, such as the one from Flask,\u001b[m  \u001b[5;7H\u001b[34mas a callback argument. Using werkzeug.Response directly makes a\u001b[m\r\n\u001b[38;5;130m44\u001b[m\u001b[4C\u001b[34mcallback annotated with flask.Response fail type checking.\u001b[m\u001b[7;5HResponseClass = t.TypeVar(\u001b[31m\"ResponseClass\"\u001b[m, bound=\u001b[31m\"Response\"\u001b[m)\u001b[8;5H                                              \u001b[9;5HAppOrBlueprintKey = t.Optional[\u001b[36mstr\u001b[m]  \u001b[34m# The App key is None, whereas blueprints are named\u001b[m\u001b[10;5HAfterRequestCallable = t.Union[              \u001b[11;21HResponseClass], ResponseClass],           \u001b[12;5H    t.Callable[[ResponseClass], t.Awaitable[ResponseClass]],\u001b[14;3H\u001b[38;5;130m6\r\n  5\r\n  4\r\n  3\r\n  2\r\n  1\r\n13\u001b[m\u001b[2C\u001b[34m\u001b[103mvenv/lib/python3.13/site-packages/flask/typing.py\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[38;5;130m\u001b[103m44 col 27\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[103m # callback annotated with f\u001b[m\u001b[21;1H\u001b[38;5;130m  1\u001b[m\u001b[1C\u001b[34mvenv/lib/python3.13/site-packages/flask/typing.py\u001b[m\u001b[35m|\u001b[m\u001b[38;5;130m79 col 30\u001b[m\u001b[35m|\u001b[m # https://github.com/pallet\u001b[22;3H\u001b[38;5;130m2\r\n  3\u001b[m\u001b[24;76H\u001b[7m1\u001b[m\u001b[13;75H\u001b[1m\u001b[7m44,27 \u001b[9C48%\u001b[6;31H\u001b[?25h"]

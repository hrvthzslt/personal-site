[15.807317, "o", "\u001b[1;9Hlocal.__release_local__()\u001b[2;5H                                                                        \u001b[3;5H                                                                \u001b[4;5H\u001b[38;5;130mclass\u001b[m \u001b[36mLocal\u001b[m:                                 \u001b[5;5H    \u001b[31m\"\"\"Create a namespace of context-local data. This wraps a\u001b[m\r\n\u001b[38;5;130m37\u001b[m\u001b[2C\u001b[31m    :class:`ContextVar` containing a :class:`dict` value.\u001b[m                \u001b[7;5H                                                                     \u001b[8;5H\u001b[31m    This may incur a performance penalty compared to using individual\u001b[9;5H    context vars, as it has to copy data to avoid mutating the dict\u001b[10;5H    between nested contexts.\u001b[m                              \u001b[11;9H                                                   \u001b[12;5H\u001b[31m    :param context_var: The :class:`~contextvars.ContextVar` to use as\u001b[m\r\n\u001b[1m\u001b[7mvenv/lib/python3.13/site-packages/werkzeug/local.py                       37,13           4%\u001b[m\u001b[14;1H\u001b[38;5;130m  1\u001b[m\u001b[1C\u001b[34mvenv/lib/python3.13/site-packages/werkzeug/local.py\u001b[m\u001b[35m|\u001b[m\u001b[38;5;130m7 col 25\u001b[m\u001b[35m|\u001b[m from contextvars import Co\u001b[15;1H\u001b[38;5;130m2  \u001b[m\u001b[1C\u001b[34m\u001b[103mvenv/lib/python3.13/site-packages/werkzeug/local.py\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[38;5;130m\u001b[103m37 col 13\u001b[m\u001b[35m\u001b[103m|\u001b[m\u001b[103m :class:`ContextVar` conta\u001b[m\u001b[16;3H\u001b[38;5;130m1\r\n  2\r\n  3\r\n  4\r\n  5\r\n  6\r\n  7\r\n  8\u001b[m\r\n\u001b[7m<idden --no-ignore -g '!tags' -g '!.git/**' -w -g \"*.py\" -- 'ContextVar' 2,1             Top\u001b]2;local.py (~/workspace/personal/markdo...thon3.13/site-packages/werkzeug) - VIM\u0007\u001b[6;17H\u001b[?25h"]

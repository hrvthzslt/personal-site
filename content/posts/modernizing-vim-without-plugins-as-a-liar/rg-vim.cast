[12.600499, "o", "\u001b[1;9H\u001b[95mview function.  This for example creates a response with a 404 error\u001b[2;5H    code::\u001b[m\u001b[3;5H                    \u001b[4;2H\u001b[93m50\u001b[m\u001b[9C\u001b[95mresponse = make_response(render_template('not_found.html'), 404)\u001b[m \u001b[5;5H                                                                    \u001b[6;9H\u001b[95mThe other use case of this function is to force the return value of a\u001b[7;5H    view function into a response which is helpful with view\u001b[8;9Hdecorators::\u001b[m                                                       \u001b[10;3H\u001b[93m5\r\n  4\r\n  3\r\n  2\r\n  1\u001b[m\u001b[1C\u001b[38;5;159mvenv/lib/python3.13/site-packages/flask/helpers.py\u001b[m\u001b[38;5;224m|\u001b[m\u001b[93m142 col 38\u001b[m\u001b[38;5;224m|\u001b[m response =\u001b[15;1H\u001b[93m6  \u001b[m\u001b[1C\u001b[30m\u001b[103mvenv/lib/python3.13/site-packages/flask/helpers.py|150 col 34| response =\u001b[m\u001b[16;3H\u001b[93m1\r\n  2\r\n  3\r\n  4\u001b[m\u001b[20;59H\u001b[7m6\u001b[m\u001b[9;61H\u001b[1m\u001b[7m50,34 \u001b[9C3%\u001b[4;38H\u001b[?25h"]
[14.50943, "o", "\u001b[?25l\u001b[m\u001b[1;3H\u001b[93m8\u001b[m\u001b[5C\u001b[95m        response = make_response(render_template('index.html', foo=42\u001b[m\u001b[2;3H\u001b[93m7\u001b[m\u001b[5C\u001b[95m        response.headers['X-Parachutes'] = 'parachutes are cool'\u001b[m\u001b[3;3H\u001b[93m6\u001b[m\u001b[1C\u001b[95m            return response\u001b[m\r\n\u001b[93m  5\u001b[m\u001b[1C                                                                        \u001b[5;3H\u001b[93m4\u001b[m\u001b[1C\u001b[95m    This function accepts the very same arguments you can return from a\u001b[m\u001b[6;3H\u001b[93m3\u001b[m\u001b[5C\u001b[95mview function.  This for example creates a response with a 404 error\u001b[m \u001b[7;3H\u001b[93m2\u001b[m\u001b[5C\u001b[95mcode::\u001b[m                                                  \u001b[8;3H\u001b[93m1\u001b[m\u001b[1C                \r\n\u001b[93m150 \u001b[m\u001b[95m        response = make_response(render_template('not_found.html'), 404)\u001b[m \u001b[10;3H\u001b[93m1\u001b[m\u001b[1C                                                                         \u001b[11;3H\u001b[93m2\u001b[m\u001b[1C\u001b[95m    The other use case of this function is to force the return value of a\u001b[12;5H    view function into a response which is helpful with view\u001b[m         \u001b[13;3H\u001b[93m4\u001b[m\u001b[1C\u001b[95m    decorators::\u001b[m                                                         \u001b[14;3H\u001b[93m5\u001b[m\u001b[1C                                                                         \u001b[15;1H\u001b[93m  6\u001b[m\u001b[1C\u001b[95m        response = make_response(view_function())\u001b[m                        \u001b[16;3H\u001b[93m7\u001b[m\u001b[1C\u001b[95m        response.headers['X-Parachutes'] = 'parachutes are cool'\u001b[m         \u001b[17;3H\u001b[93m8\u001b[m\u001b[1C                                                                         \u001b[18;3H\u001b[93m9\u001b[m\u001b[1C\u001b[95m    Internally this function does the following things:\u001b[m                  \u001b[19;2H\u001b[93m10\u001b[m\u001b[1C                                                                         \u001b[20;1H\u001b[1m\u001b[7mvenv/lib/python3.13/site-packages/flask/helpers.py         150,34         23%\u001b[9;38H\u001b[?25h"]
